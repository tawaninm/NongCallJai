generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id              String            @id @default(cuid())
  payerName       String
  phone           String
  email           String?
  planId          String
  setupStatus     String            @default("waiting_line")
  createdAt       DateTime          @default(now())
  auditLogs       AuditLog[]
  automationJobs  AutomationJob[]
  botnoiMappings  BotnoiMapping[]
  elders          ElderProfile[]
  lineConnections LineConnection[]
  notifications   NotificationLog[]
  subscriptions   Subscription[]
}

model Subscription {
  id         String   @id @default(cuid())
  customerId String
  planId     String
  status     String   @default("trial")
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id])
}

model ElderProfile {
  id             String          @id @default(cuid())
  customerId     String
  name           String
  nickname       String?
  phone          String
  relationship   String
  note           String?
  consentGranted Boolean         @default(false)
  createdAt      DateTime        @default(now())
  botnoiMappings BotnoiMapping[]
  consentRecords ConsentRecord[]
  customer       Customer        @relation(fields: [customerId], references: [id])
}

model ConsentRecord {
  id             String       @id @default(cuid())
  elderProfileId String
  consentType    String
  status         String
  updatedAt      DateTime     @updatedAt
  elderProfile   ElderProfile @relation(fields: [elderProfileId], references: [id])
}

model LineConnection {
  id          String    @id @default(cuid())
  customerId  String
  lineUserId  String?
  displayName String?
  pictureUrl  String?
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  linkedAt    DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  customer    Customer  @relation(fields: [customerId], references: [id])
}

model BotnoiMapping {
  id              String        @id @default(cuid())
  customerId      String
  elderProfileId  String?
  botnoiBotId     String
  botnoiContactId String
  status          String        @default("draft")
  updatedAt       DateTime      @updatedAt
  customer        Customer      @relation(fields: [customerId], references: [id])
  elderProfile    ElderProfile? @relation(fields: [elderProfileId], references: [id])
}

model CallFeedbackLog {
  id                String   @id @default(cuid())
  botnoiBotId       String
  botnoiContactId   String
  callStatus        String
  startedAt         DateTime
  summary           String?
  transcript        String?
  audioUrl          String?
  tags              Json?
  createdAt         DateTime @default(now())
  caring_message    String?
  meal              Boolean?
  meal_detail       String?
  medication_detail String?
  medication_status Boolean?
  today_activity    String?
}

model NotificationLog {
  id             String    @id @default(cuid())
  customerId     String
  elderName      String
  title          String
  summary        String
  alertLevel     String
  audioUrl       String?
  safeNote       String
  deliveryStatus String    @default("pending")
  lineMessageId  String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  customer       Customer  @relation(fields: [customerId], references: [id])
}

model AutomationJob {
  id             String    @id @default(cuid())
  type           String
  status         String    @default("queued")
  customerId     String?
  elderProfileId String?
  scheduledAt    DateTime  @default(now())
  startedAt      DateTime?
  finishedAt     DateTime?
  attemptCount   Int       @default(0)
  maxAttempts    Int       @default(3)
  lastError      String?
  payload        Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  customer       Customer? @relation(fields: [customerId], references: [id])

  @@index([status, scheduledAt])
  @@index([customerId])
}

model ApiClient {
  id          String          @id @default(cuid())
  name        String
  clientType  String
  secretHash  String
  status      String          @default("active")
  createdAt   DateTime        @default(now())
  requestLogs ApiRequestLog[]
}

model ApiRequestLog {
  id          String     @id @default(cuid())
  apiClientId String?
  method      String
  endpoint    String
  statusCode  Int
  requestId   String
  createdAt   DateTime   @default(now())
  apiClient   ApiClient? @relation(fields: [apiClientId], references: [id])

  @@index([apiClientId, createdAt])
  @@index([requestId])
}

model AuditLog {
  id         String    @id @default(cuid())
  customerId String?
  action     String
  createdAt  DateTime  @default(now())
  customer   Customer? @relation(fields: [customerId], references: [id])
}
{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "dist/server/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nongcalljai-api.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/server/server.js"
    }
  ]
}